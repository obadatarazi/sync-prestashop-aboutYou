# ------ Sync ------
SYNC_BATCH_SIZE=50
SYNC_INCREMENTAL=true
SYNC_LOCK_FILE=./logs/sync-run.lock
SYNC_MAX_EXECUTION_TIME=0
TEST_MODE=true
DRY_RUN=false
PRODUCT_SYNC_MAX_ATTEMPTS=3
ORDER_IMPORT_MAX_ATTEMPTS=3
STOCK_SYNC_MAX_ITEMS=0
AY_ALLOW_MISSING_COMBINATION_ATTRIBUTES=true
AY_STRICT_PREFLIGHT=true
AY_SKIP_DUPLICATE_TUPLE_VARIANTS=false
# ------ Images (3:4 ratio, min 1125x1500) ------
IMAGE_NORMALIZE_FOR_AY=true
IMAGE_NORMALIZE_PUBLIC_BASE_URL=https://scr-wear.com/ay-normalized
IMAGE_NORMALIZE_VERBOSE_SKIPS=false

# ------ Logging ------
LOG_LEVEL=info
LOG_PATH=./logs/sync.log
LOG_MAX_FILES=30

# ------ Notifications ------
NOTIFY_SLACK_ENABLED=true
NOTIFY_SLACK_WEBHOOK=
NOTIFY_EMAIL_ENABLED=false
NOTIFY_EMAIL_TO=
NOTIFY_EMAIL_FROM=sync@example.com

# ------ Web UI ------
