APP_URL=http://localhost:8080
APP_TIMEZONE=UTC

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=syncbridge
DB_USER=root
DB_PASSWORD=

PS_BASE_URL=https://your-prestashop.example.com
PS_API_KEY=
PS_LANGUAGE_ID=1
PS_SHOP_ID=1
PS_DEFAULT_CARRIER_ID=
PS_DEFAULT_CURRENCY_ID=1
PS_ORDER_STATE_ID=3
PS_ORDER_MODULE=syncbridge
PS_ORDER_PAYMENT=Marketplace
PS_PAGE_SIZE=100
PS_TIMEOUT_SEC=60
PS_MIN_INTERVAL_MS=100

AY_BASE_URL=https://partner.aboutyou.com/api/v1
# Optional; some networks block the default PHP/cURL User-Agent — set a custom string if you get HTML 403 pages.
# AY_USER_AGENT=
AY_API_KEY=
AY_BRAND_ID=
AY_CATEGORY_ID=
AY_COUNTRY_CODES=NL
AY_AUTO_PUBLISH=true
AY_DESCRIPTION_LOCALE=en
# Product batches can sit in pending/processing for minutes; raise these if you see batch timeouts.
AY_BATCH_POLL_ATTEMPTS=25
AY_BATCH_POLL_MS=2000
AY_TIMEOUT_SEC=60
AY_MIN_INTERVAL_MS=650
# When true (default), per-path spacing follows AyDocsPolicy limits under partner rate caps (recommended for large catalog sync).
FEATURE_AY_ADAPTIVE_THROTTLE=true
AY_DEFAULT_COUNTRY_OF_ORIGIN=DE
# Stock/price batch chunk size (ProductSyncService); keep under AY limits.
AY_STOCK_PRICE_BATCH_SIZE=500
# Country code sent on stock/price rows when not derived from PS (ISO 3166-1 alpha-2).
AY_DEFAULT_COUNTRY_CODE=DE
AY_DEFAULT_CARRIER_KEY=
# Order list page size (1–100) for GET /orders/ during import.
AY_ORDER_PAGE_SIZE=100
# Safety cap on order-list pages per run (cursor + page modes).
AY_ORDERS_MAX_PAGES=100
# Preflight / mapper: require category attribute metadata before push; strict blocks questionable payloads.
AY_REQUIRE_CATEGORY_METADATA=true
AY_STRICT_PREFLIGHT=true
# If the API omits "required" on groups, treat all groups as required when mapping (use sparingly).
AY_ASSUME_CATEGORY_GROUPS_REQUIRED=false
# Comma-separated AY text-field keys appended to required-text validation (material, care labels, etc.).
AY_FALLBACK_REQUIRED_TEXT_FIELDS=material_composition_textile
# If the primary /categories/{id}/attribute-groups route fails, try legacy underscore / plural paths (sandbox vs live differences).
AY_ENABLE_LEGACY_ATTRIBUTE_ENDPOINTS=false
# Mapper: max images per variant, duplicate-tuple handling, optional fallbacks (see AboutYouMapper).
AY_MAX_IMAGES=7
AY_SKIP_DUPLICATE_TUPLE_VARIANTS=false
AY_ALLOW_MISSING_COMBINATION_ATTRIBUTES=false
AY_ALLOW_DESCRIPTION_FALLBACK=false
# Default AY attribute IDs when PS cannot resolve color/size (0 = disabled).
AY_DEFAULT_COLOR_ID=0
AY_DEFAULT_SIZE_ID=0
AY_DEFAULT_SECOND_SIZE_ID=0
# Optional default textile composition string when PS field is empty.
# AY_DEFAULT_MATERIAL_COMPOSITION_TEXTILE=
# JSON maps for material resolver (see MaterialCompositionResolver).
AY_MATERIAL_COMPONENT_MAP={}
AY_MATERIAL_COMPONENT_NON_TEXTILE_MAP={}
AY_MATERIAL_CLUSTER_MAP={}
AY_DEFAULT_MATERIAL_CLUSTER_ID=1
AY_CATEGORY_MAP={}
AY_BRAND_MAP={}
PS_TO_AY_STATUS_MAP={}
# UI / direct API helpers in public/api.php (optional; falls back to AY_TIMEOUT_SEC-style behavior in client).
AY_HTTP_TIMEOUT=15
AY_HTTP_CONNECT_TIMEOUT=8
# Skip pushing PS→AY status when DB already records the same AY status (reduces duplicate ship calls).
FEATURE_IDEMPOTENT_STATUS_PUSH=true

IMAGE_NORMALIZE_ENABLED=true
IMAGE_PUBLIC_BASE_URL=http://localhost:8080/ay-normalized
IMAGE_JPEG_QUALITY=92

HTTP_TIMEOUT_SEC=30
HTTP_MAX_RETRIES=3
ORDER_IMPORT_MAX_ATTEMPTS=3
SYNC_LOCK_FILE=logs/sync-run.lock

TEST_MODE=true
DRY_RUN=false

NOTIFY_SLACK_ENABLED=false
NOTIFY_SLACK_WEBHOOK=
