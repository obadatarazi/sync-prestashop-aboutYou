{
    "openapi": "3.0.0",
    "info": {
        "title": "SyncBridge API",
        "description": "Production-grade API documentation for SyncBridge integration endpoints.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "http://127.0.0.1:8080",
            "description": "Primary API server"
        }
    ],
    "paths": {
        "/api/legacy": {
            "get": {
                "tags": [
                    "Legacy"
                ],
                "summary": "Legacy endpoint (GET)",
                "description": "Legacy compatibility endpoint. Uses action query parameter to route behavior.",
                "operationId": "legacyHandleGet",
                "parameters": [
                    {
                        "name": "action",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "status",
                                "products",
                                "orders",
                                "settings",
                                "settings_save",
                                "sync"
                            ]
                        }
                    },
                    {
                        "name": "command",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "example": "products"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Legacy action succeeded",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Unsupported legacy action",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Legacy sync failed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "Legacy"
                ],
                "summary": "Legacy endpoint (POST)",
                "description": "Legacy compatibility endpoint. Accepts body payload for action dispatching.",
                "operationId": "legacyHandlePost",
                "requestBody": {
                    "required": false,
                    "content": {
                        "application/json": {
                            "schema": {
                                "properties": {
                                    "action": {
                                        "type": "string",
                                        "enum": [
                                            "status",
                                            "products",
                                            "orders",
                                            "settings",
                                            "settings_save",
                                            "sync"
                                        ]
                                    },
                                    "command": {
                                        "type": "string",
                                        "example": "products"
                                    },
                                    "settings": {
                                        "type": "object",
                                        "additionalProperties": true
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Legacy action succeeded",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Unsupported legacy action",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Legacy sync failed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/orders": {
            "get": {
                "tags": [
                    "Orders"
                ],
                "summary": "List orders",
                "description": "Returns paginated order records.",
                "operationId": "ordersIndex",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 1,
                            "minimum": 1
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 20,
                            "maximum": 200,
                            "minimum": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Orders fetched successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        {
                                            "$ref": "#/components/schemas/ApiSuccessBase"
                                        },
                                        {
                                            "properties": {
                                                "total": {
                                                    "type": "integer",
                                                    "example": 80
                                                },
                                                "page": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "per_page": {
                                                    "type": "integer",
                                                    "example": 20
                                                },
                                                "rows": {
                                                    "type": "array",
                                                    "items": {
                                                        "$ref": "#/components/schemas/Order"
                                                    }
                                                }
                                            },
                                            "type": "object"
                                        }
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/orders/{orderId}": {
            "get": {
                "tags": [
                    "Orders"
                ],
                "summary": "Get order details",
                "description": "Returns order details and order items.",
                "operationId": "ordersShow",
                "parameters": [
                    {
                        "name": "orderId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "minimum": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Order details fetched successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        {
                                            "$ref": "#/components/schemas/ApiSuccessBase"
                                        },
                                        {
                                            "properties": {
                                                "order": {
                                                    "$ref": "#/components/schemas/Order"
                                                },
                                                "items": {
                                                    "type": "array",
                                                    "items": {
                                                        "$ref": "#/components/schemas/OrderItem"
                                                    }
                                                }
                                            },
                                            "type": "object"
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Order not found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/products": {
            "get": {
                "tags": [
                    "Products"
                ],
                "summary": "List products",
                "description": "Returns paginated products with optional filtering and search.",
                "operationId": "productsIndex",
                "parameters": [
                    {
                        "name": "page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 1,
                            "minimum": 1
                        }
                    },
                    {
                        "name": "per_page",
                        "in": "query",
                        "schema": {
                            "type": "integer",
                            "default": 20,
                            "maximum": 200,
                            "minimum": 1
                        }
                    },
                    {
                        "name": "status",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "enum": [
                                "synced",
                                "pending",
                                "error",
                                "syncing",
                                "quarantined"
                            ]
                        }
                    },
                    {
                        "name": "search",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "maxLength": 255
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Products fetched successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        {
                                            "$ref": "#/components/schemas/ApiSuccessBase"
                                        },
                                        {
                                            "properties": {
                                                "total": {
                                                    "type": "integer",
                                                    "example": 245
                                                },
                                                "page": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "per_page": {
                                                    "type": "integer",
                                                    "example": 20
                                                },
                                                "rows": {
                                                    "type": "array",
                                                    "items": {
                                                        "$ref": "#/components/schemas/Product"
                                                    }
                                                }
                                            },
                                            "type": "object"
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/products/{productId}": {
            "get": {
                "tags": [
                    "Products"
                ],
                "summary": "Get product details",
                "description": "Returns product details with variants and images.",
                "operationId": "productsShow",
                "parameters": [
                    {
                        "name": "productId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "minimum": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Product details fetched successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        {
                                            "$ref": "#/components/schemas/ApiSuccessBase"
                                        },
                                        {
                                            "properties": {
                                                "product": {
                                                    "$ref": "#/components/schemas/Product"
                                                },
                                                "variants": {
                                                    "type": "array",
                                                    "items": {
                                                        "$ref": "#/components/schemas/ProductVariant"
                                                    }
                                                },
                                                "images": {
                                                    "type": "array",
                                                    "items": {
                                                        "$ref": "#/components/schemas/ProductImage"
                                                    }
                                                }
                                            },
                                            "type": "object"
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Product not found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/settings": {
            "get": {
                "tags": [
                    "Settings"
                ],
                "summary": "List settings",
                "description": "Returns current settings grouped by persisted key/value rows.",
                "operationId": "settingsIndex",
                "responses": {
                    "200": {
                        "description": "Settings fetched successfully",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        {
                                            "$ref": "#/components/schemas/ApiSuccessBase"
                                        },
                                        {
                                            "properties": {
                                                "rows": {
                                                    "type": "array",
                                                    "items": {
                                                        "$ref": "#/components/schemas/Setting"
                                                    }
                                                }
                                            },
                                            "type": "object"
                                        }
                                    ]
                                }
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "Settings"
                ],
                "summary": "Save settings",
                "description": "Persists one or more settings values.",
                "operationId": "settingsSave",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/SettingsSaveRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Settings saved",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        {
                                            "$ref": "#/components/schemas/ApiSuccessBase"
                                        },
                                        {
                                            "properties": {
                                                "saved": {
                                                    "type": "array",
                                                    "items": {
                                                        "type": "string",
                                                        "example": "sync.batch_size"
                                                    }
                                                }
                                            },
                                            "type": "object"
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Invalid settings payload",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    },
                    {
                        "apiTokenHeader": []
                    }
                ]
            }
        },
        "/api/v1/sync": {
            "post": {
                "tags": [
                    "Sync"
                ],
                "summary": "Run sync command",
                "description": "Executes a supported sync command and returns run metadata.",
                "operationId": "syncRun",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/SyncCommandRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Sync command executed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        {
                                            "$ref": "#/components/schemas/ApiSuccessBase"
                                        },
                                        {
                                            "properties": {
                                                "run_id": {
                                                    "type": "integer",
                                                    "example": 1001,
                                                    "nullable": true
                                                },
                                                "result": {
                                                    "type": "object",
                                                    "additionalProperties": true
                                                }
                                            },
                                            "type": "object"
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Sync execution failure",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    },
                    {
                        "apiTokenHeader": []
                    }
                ]
            }
        },
        "/api/v1/sync/products": {
            "post": {
                "tags": [
                    "Sync"
                ],
                "summary": "Run product sync for specific product IDs",
                "description": "Runs products sync for the provided PrestaShop product IDs. Defaults to incremental mode.",
                "operationId": "syncRunProductsByIds",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/ProductSyncRequest"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Product sync command executed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "allOf": [
                                        {
                                            "$ref": "#/components/schemas/ApiSuccessBase"
                                        },
                                        {
                                            "properties": {
                                                "run_id": {
                                                    "type": "string",
                                                    "example": "f0e1d2c3b4a59687",
                                                    "nullable": true
                                                },
                                                "result": {
                                                    "type": "object",
                                                    "additionalProperties": true
                                                }
                                            },
                                            "type": "object"
                                        }
                                    ]
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    },
                    "500": {
                        "description": "Sync execution failure",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ApiError"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "bearerAuth": []
                    },
                    {
                        "apiTokenHeader": []
                    }
                ]
            }
        }
    },
    "components": {
        "schemas": {
            "ApiSuccessBase": {
                "required": [
                    "ok",
                    "message"
                ],
                "properties": {
                    "ok": {
                        "type": "boolean",
                        "example": true
                    },
                    "message": {
                        "type": "string",
                        "example": "ok"
                    }
                },
                "type": "object"
            },
            "ApiError": {
                "required": [
                    "ok",
                    "error",
                    "errors"
                ],
                "properties": {
                    "ok": {
                        "type": "boolean",
                        "example": false
                    },
                    "error": {
                        "type": "string",
                        "example": "Invalid payload"
                    },
                    "errors": {
                        "type": "object",
                        "additionalProperties": {
                            "schema": "OpenApiSpec",
                            "type": "array",
                            "items": {
                                "type": "string",
                                "example": "The field is required."
                            }
                        }
                    }
                },
                "type": "object"
            },
            "OpenApiSpec": {
                "type": "array",
                "items": {
                    "type": "string",
                    "example": "The field is required."
                }
            },
            "PaginationMeta": {
                "required": [
                    "total",
                    "page",
                    "per_page"
                ],
                "properties": {
                    "total": {
                        "type": "integer",
                        "example": 245
                    },
                    "page": {
                        "type": "integer",
                        "example": 1
                    },
                    "per_page": {
                        "type": "integer",
                        "example": 20
                    }
                },
                "type": "object"
            },
            "Product": {
                "required": [
                    "id",
                    "ps_id",
                    "name",
                    "sync_status"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 10
                    },
                    "ps_id": {
                        "type": "integer",
                        "example": 12345
                    },
                    "name": {
                        "type": "string",
                        "example": "Slim Fit Denim Jacket"
                    },
                    "reference": {
                        "type": "string",
                        "example": "REF-123",
                        "nullable": true
                    },
                    "sync_status": {
                        "type": "string",
                        "example": "synced"
                    },
                    "sync_error": {
                        "type": "string",
                        "example": null,
                        "nullable": true
                    },
                    "ay_style_key": {
                        "type": "string",
                        "example": "BY-STYLE-123",
                        "nullable": true
                    },
                    "price": {
                        "type": "number",
                        "format": "float",
                        "example": 89.99
                    },
                    "updated_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "ProductVariant": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 7
                    },
                    "product_id": {
                        "type": "integer",
                        "example": 10
                    },
                    "ps_combo_id": {
                        "type": "integer",
                        "example": 1001,
                        "nullable": true
                    },
                    "sku": {
                        "type": "string",
                        "example": "SKU-BLACK-M",
                        "nullable": true
                    },
                    "ean13": {
                        "type": "string",
                        "example": "4006381333931",
                        "nullable": true
                    },
                    "reference": {
                        "type": "string",
                        "example": "REF-BLK-M",
                        "nullable": true
                    },
                    "price_modifier": {
                        "type": "number",
                        "format": "float",
                        "example": 0
                    },
                    "weight": {
                        "type": "number",
                        "format": "float",
                        "example": 0.2
                    },
                    "quantity": {
                        "type": "integer",
                        "example": 5
                    },
                    "color_id": {
                        "type": "integer",
                        "example": 2,
                        "nullable": true
                    },
                    "size_id": {
                        "type": "integer",
                        "example": 4,
                        "nullable": true
                    },
                    "ay_pushed": {
                        "type": "boolean",
                        "example": true
                    }
                },
                "type": "object"
            },
            "ProductImage": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 3
                    },
                    "product_id": {
                        "type": "integer",
                        "example": 10
                    },
                    "ps_image_id": {
                        "type": "integer",
                        "example": 9001
                    },
                    "source_url": {
                        "type": "string",
                        "example": "https://cdn.example.com/img/source.jpg",
                        "nullable": true
                    },
                    "public_url": {
                        "type": "string",
                        "example": "https://cdn.example.com/img/public.jpg",
                        "nullable": true
                    },
                    "status": {
                        "type": "string",
                        "example": "processed",
                        "nullable": true
                    },
                    "error_message": {
                        "type": "string",
                        "example": null,
                        "nullable": true
                    },
                    "position": {
                        "type": "integer",
                        "example": 1,
                        "nullable": true
                    },
                    "processed_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "Order": {
                "required": [
                    "id",
                    "sync_status"
                ],
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 14
                    },
                    "ay_order_id": {
                        "type": "string",
                        "example": "AY-ORDER-123",
                        "nullable": true
                    },
                    "ps_order_id": {
                        "type": "integer",
                        "example": 345,
                        "nullable": true
                    },
                    "sync_status": {
                        "type": "string",
                        "example": "synced"
                    },
                    "ay_status": {
                        "type": "string",
                        "example": "approved",
                        "nullable": true
                    },
                    "total_paid": {
                        "type": "number",
                        "format": "float",
                        "example": 129.49
                    },
                    "created_at": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    }
                },
                "type": "object"
            },
            "OrderItem": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "example": 55
                    },
                    "order_id": {
                        "type": "integer",
                        "example": 14
                    },
                    "ay_order_item_id": {
                        "type": "string",
                        "example": "item-001",
                        "nullable": true
                    },
                    "sku": {
                        "type": "string",
                        "example": "SKU-TEE-M",
                        "nullable": true
                    },
                    "ean13": {
                        "type": "string",
                        "example": "4006381333931",
                        "nullable": true
                    },
                    "product_id": {
                        "type": "integer",
                        "example": 100,
                        "nullable": true
                    },
                    "combo_id": {
                        "type": "integer",
                        "example": 200,
                        "nullable": true
                    },
                    "quantity": {
                        "type": "integer",
                        "example": 2
                    },
                    "unit_price": {
                        "type": "number",
                        "format": "float",
                        "example": 19.99
                    },
                    "discount_amount": {
                        "type": "number",
                        "format": "float",
                        "example": 0
                    },
